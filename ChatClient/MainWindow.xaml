<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="💬 Chat Client" Height="400" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtHistory" Grid.Row="0" IsReadOnly="True" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>

        <TextBox x:Name="txtMessage" Grid.Row="1" Margin="0,0,0,5" 
                 KeyDown="TxtMessage_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnConnect" Content="🔗 Connect" Width="80" Margin="0,0,5,0" Click="BtnConnect_Click"/>
            <Button Content="📤 Send" Width="80" Click="BtnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>
